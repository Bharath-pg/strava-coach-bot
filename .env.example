# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# LLM Provider: "groq" (default) or "gemini"
LLM_PROVIDER=groq

# Groq (free tier -- https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# Google Gemini (alternative -- https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://assistant:assistant@localhost:5432/assistant_db

# Optional: restrict bot to specific Telegram user IDs (comma-separated)
ALLOWED_USER_IDS=

# Strava API (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Logging
LOG_LEVEL=INFO
